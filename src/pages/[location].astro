---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import PostHogLayout from '../layouts/PostHogLayout.astro';
import ReviewCard from '../components/ReviewCard.astro';
import { Leaf, Wheat, Laptop, Coffee, Salad, Croissant } from 'lucide-astro';
import { getAllLocations, getAllBlogPosts, getSiteConfig } from '../lib/sanity-utils';
import { urlFor } from '../lib/sanity';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL } from '../consts';

export async function getStaticPaths() {
  const locations = await getAllLocations();
  
  return locations.map((location) => ({
    params: { location: location.slug.current },
    props: { location }
  }));
}

const { location } = Astro.props;
const allCafes = await getAllBlogPosts();

// Filter cafes for this location
const locationCafes = allCafes.filter(cafe => 
  cafe.location?.slug === location.slug.current
);

let siteTitle = SITE_TITLE;
let siteDescription = SITE_DESCRIPTION;

try {
  const siteConfig = await getSiteConfig();
  if (siteConfig) {
    siteTitle = siteConfig.title || siteTitle;
    siteDescription = siteConfig.description || siteDescription;
  }
} catch (error) {
  console.error('Failed to load site config for meta tags:', error);
}

// SEO-optimised title pattern with target keywords.
const pageTitle = `Best Cafes in ${location.cityName} – Vegan, Gluten-Free, Workable | ${siteTitle}`;
const pageDescription = location.description
  ? location.description.slice(0, 160)
  : `Honest reviews of the best cafes in ${location.cityName} — vegan, gluten-free, coffee craftsmanship, workability and pastries.`;

const locationUrl = `${SITE_URL}/${location.slug.current}`;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: location.cityName, item: locationUrl },
  ],
};

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: locationUrl,
  isPartOf: {
    '@type': 'WebSite',
    name: siteTitle,
    url: SITE_URL,
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: locationCafes.map((cafe, idx) => ({
      '@type': 'ListItem',
      position: idx + 1,
      url: `${SITE_URL}/blog/${cafe.slug}`,
      name: cafe.title,
    })),
  },
};

// Get all banner images from bannerImages array
const bannerImageUrls = location.bannerImages?.map(image => 
  urlFor(image).width(1920).height(1080).url()
) || [];
---

<PostHogLayout>
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(collectionJsonLd)} />
  </head>
  <body>
    <main class="homepage-main">
      <Hero cityName={location.cityName} bannerImageUrls={bannerImageUrls} showScrollIndicator={true} featuredCafes={locationCafes.sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime()).slice(0, 4)} />
      
      <section class="location-reviews">
        <div class="container">
          {location.description && (
            <div class="section-header">
              <p class="location-description">{location.description}</p>
            </div>
          )}
          
          {locationCafes.length > 0 && (
            <div class="best-for-section">
              <h3 class="best-for-title">Best for...</h3>
              <div class="filter-buttons">
                <button class="filter-btn" data-sort="vegan"><Leaf size={16} /> Vegan</button>
                <button class="filter-btn" data-sort="glutenFree"><Wheat size={16} /> Gluten Free</button>
                <button class="filter-btn" data-sort="workability"><Laptop size={16} /> Workability</button>
                <button class="filter-btn" data-sort="coffee"><Coffee size={16} /> Coffee</button>
                <button class="filter-btn" data-sort="health"><Salad size={16} /> Health</button>
                <button class="filter-btn" data-sort="pastries"><Croissant size={16} /> Pastries</button>
              </div>
            </div>
          )}

          {locationCafes.length > 0 ? (
            <div class="reviews-grid" id="reviews-grid">
              {locationCafes.map((cafe) => (
                <div 
                  class="review-item"
                  data-vegan={cafe.veganOptions || 0}
                  data-gluten-free={cafe.glutenFree || 0}
                  data-workability={cafe.workability || 0}
                  data-coffee={cafe.coffeeCraftsmanship || 0}
                  data-health={cafe.healthFocus || 0}
                  data-pastries={cafe.pastries || 0}
                  data-date={cafe.pubDate.getTime()}
                >
                  <ReviewCard
                    title={cafe.title}
                    slug={cafe.slug}
                    description={cafe.description}
                    heroImage={cafe.heroImage}
                    rating={cafe.rating}
                    location={cafe.location}
                    hideLocation={true}
                    veganOptions={cafe.veganOptions}
                    glutenFree={cafe.glutenFree}
                    workability={cafe.workability}
                    coffeeCraftsmanship={cafe.coffeeCraftsmanship}
                    healthFocus={cafe.healthFocus}
                    pastries={cafe.pastries}
                  />
                </div>
              ))}
            </div>
          ) : (
            <div class="no-reviews">
              <p>No reviews available for {location.cityName} yet. Check back soon!</p>
            </div>
          )}
        </div>
      </section>
    </main>
    <Footer />
    
    <script>
      const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
      const reviewsGrid = document.getElementById('reviews-grid');

      const categoryMap: Record<string, string> = {
        vegan: 'vegan',
        glutenFree: 'glutenFree',
        workability: 'workability',
        coffee: 'coffee',
        health: 'health',
        pastries: 'pastries',
      };

      function clearHighlights() {
        document.querySelectorAll('.rating-item.highlighted').forEach(el => el.classList.remove('highlighted'));
      }

      if (filterBtns.length && reviewsGrid) {
        filterBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const wasActive = btn.classList.contains('active');
            filterBtns.forEach(b => b.classList.remove('active'));
            clearHighlights();

            const items = Array.from(reviewsGrid.children) as HTMLElement[];

            if (wasActive) {
              // Deselect: show all, revert to newest
              items.forEach(item => {
                (item as HTMLElement).style.display = '';
              });
              items.sort((a, b) => {
                const aVal = parseFloat(a.dataset.date || '0');
                const bVal = parseFloat(b.dataset.date || '0');
                return bVal - aVal;
              });
              items.forEach(item => reviewsGrid.appendChild(item));
              return;
            }
            btn.classList.add('active');

            const sortBy = btn.dataset.sort;
            const dataAttr = categoryMap[sortBy || ''] || 'date';

            // Hide items without a rating for this category, show the rest
            items.forEach(item => {
              const val = parseFloat(item.dataset[dataAttr] || '0');
              (item as HTMLElement).style.display = val > 0 ? '' : 'none';
            });

            // Sort visible items by the selected rating (descending)
            const visible = items.filter(item => (item as HTMLElement).style.display !== 'none');
            visible.sort((a, b) => {
              const aVal = parseFloat(a.dataset[dataAttr] || '0');
              const bVal = parseFloat(b.dataset[dataAttr] || '0');
              return bVal - aVal;
            });
            visible.forEach(item => reviewsGrid.appendChild(item));

            // Highlight the matching rating on visible cards
            visible.forEach(item => {
              const ratingEl = item.querySelector(`.rating-item[data-category="${sortBy}"]`);
              if (ratingEl) ratingEl.classList.add('highlighted');
            });
          });
        });
      }
    </script>
  </body>
</html>
</PostHogLayout>

<style>
  .homepage-main {
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0;
  }

  .location-reviews {
    padding: 4rem 0;
    background: #fafafa;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .best-for-section {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .best-for-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: #333;
    margin: 0 0 1rem 0;
  }

  .filter-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }

  .filter-btn {
    padding: 0.5rem 1.1rem;
    border: 2px solid #ddd;
    border-radius: 50px;
    background: white;
    font-size: 0.95rem;
    color: #555;
    cursor: pointer;
    transition: all 0.25s ease;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .filter-btn:hover {
    border-color: #ff6b35;
    color: #ff6b35;
  }

  .filter-btn.active {
    background: #ff6b35;
    border-color: #ff6b35;
    color: white;
  }

  .section-header h2 {
    font-size: 2.5rem;
    color: #333;
    margin: 0 0 1rem 0;
    font-weight: 700;
  }

  .location-description {
    font-size: 1.1rem;
    color: #666;
    margin: 0 0 1rem 0;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }


  .reviews-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .no-reviews {
    text-align: center;
    padding: 3rem;
    color: #666;
  }

  /* Responsive design */
  @media (max-width: 768px) {
    .location-reviews {
      padding: 3rem 0;
    }

    .container {
      padding: 0 1rem;
    }

    .reviews-grid {
      gap: 1.25rem;
    }

    .section-header h2 {
      font-size: 2rem;
    }
  }
</style>
