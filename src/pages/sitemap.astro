---
// Human-readable site index at /sitemap (in addition to the XML sitemap at
// /sitemap-index.xml). Lists every location and every cafe, grouped by city,
// pulled from Sanity at build time.
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import PostHogLayout from '../layouts/PostHogLayout.astro';
import { getAllLocations, getAllBlogPosts } from '../lib/sanity-utils';
import { SITE_TITLE } from '../consts';

const [locations, cafes] = await Promise.all([
	getAllLocations(),
	getAllBlogPosts(),
]);

type CafeRow = { title: string; slug: string };
type Group = { cityName: string; slug: string; cafes: CafeRow[] };

const groupsBySlug = new Map<string, Group>();
for (const loc of locations) {
	groupsBySlug.set(loc.slug.current, {
		cityName: loc.cityName,
		slug: loc.slug.current,
		cafes: [],
	});
}
const orphanCafes: CafeRow[] = [];
for (const cafe of cafes) {
	const slug = cafe.location?.slug;
	if (slug && groupsBySlug.has(slug)) {
		groupsBySlug.get(slug)!.cafes.push({ title: cafe.title, slug: cafe.slug });
	} else {
		orphanCafes.push({ title: cafe.title, slug: cafe.slug });
	}
}
for (const group of groupsBySlug.values()) {
	group.cafes.sort((a, b) => a.title.localeCompare(b.title));
}
const orderedGroups = Array.from(groupsBySlug.values())
	.sort((a, b) => a.cityName.localeCompare(b.cityName));

const pageTitle = `Sitemap | ${SITE_TITLE}`;
const pageDescription = 'Browse every cafe review and city on Cafe Review.';
---

<PostHogLayout>
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
	</head>
	<body class="sitemap-page">
		<main class="sitemap">
			<h1>Sitemap</h1>
			<p class="sitemap-intro">
				All cafes and locations on {SITE_TITLE}. Looking for the machine-readable version?
				See <a href="/sitemap-index.xml">/sitemap-index.xml</a>.
			</p>

			<section>
				<h2>Pages</h2>
				<ul>
					<li><a href="/">Home</a></li>
					<li><a href="/about/">About</a></li>
					<li><a href="/rss.xml">RSS feed</a></li>
				</ul>
			</section>

			<section>
				<h2>Locations</h2>
				{orderedGroups.length === 0 ? (
					<p>No locations published yet.</p>
				) : (
					<ul>
						{orderedGroups.map((group) => (
							<li>
								<a href={`/${group.slug}/`}>{group.cityName}</a>
								{group.cafes.length > 0 && (
									<ul>
										{group.cafes.map((cafe) => (
											<li>
												<a href={`/cafe/${cafe.slug}/`}>{cafe.title}</a>
											</li>
										))}
									</ul>
								)}
							</li>
						))}
					</ul>
				)}
			</section>

			{orphanCafes.length > 0 && (
				<section>
					<h2>Other reviews</h2>
					<ul>
						{orphanCafes.map((cafe) => (
							<li>
								<a href={`/cafe/${cafe.slug}/`}>{cafe.title}</a>
							</li>
						))}
					</ul>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>
</PostHogLayout>

<style>
	.sitemap-page {
		background: #fafafa;
	}
	.sitemap {
		max-width: 800px;
		margin: 0 auto;
		padding: 4rem 1.5rem 6rem;
		color: #222;
	}
	.sitemap h1 {
		font-size: 2.5rem;
		margin: 0 0 1rem 0;
	}
	.sitemap-intro {
		color: #555;
		margin-bottom: 2.5rem;
	}
	.sitemap section + section {
		margin-top: 2.5rem;
	}
	.sitemap h2 {
		font-size: 1.5rem;
		border-bottom: 1px solid #ddd;
		padding-bottom: 0.5rem;
		margin-bottom: 1rem;
	}
	.sitemap ul {
		list-style: disc;
		padding-left: 1.25rem;
		line-height: 1.8;
	}
	.sitemap a {
		color: #ff6b35;
		text-decoration: none;
	}
	.sitemap a:hover {
		text-decoration: underline;
	}
</style>
