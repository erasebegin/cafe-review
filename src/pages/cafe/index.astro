---
// import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import PostHogLayout from '../../layouts/PostHogLayout.astro';
import { SITE_TITLE } from '../../consts';
import { getAllBlogPosts } from '../../lib/sanity-utils';

const posts = await getAllBlogPosts();

const pageTitle = `All Cafe Reviews | ${SITE_TITLE}`;
const pageDescription = 'Browse every cafe review on Cafe Review. Honest ratings for vegan options, gluten-free, workability, coffee craftsmanship, health focus, and pastries across Europe.';
---

<PostHogLayout>
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			h1 {
				font-size: 2.5rem;
				margin: 0 0 0.5rem 0;
				color: var(--ink-brown);
			}
			.listing-intro {
				font-size: 1.1rem;
				color: #666;
				margin: 0 0 2.5rem 0;
				line-height: 1.6;
				max-width: 720px;
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
				h1 {
					font-size: 2rem;
				}
				.listing-intro {
					font-size: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1>All Cafe Reviews</h1>
				<p class="listing-intro">Every cafe we&rsquo;ve reviewed across Europe &mdash; sorted by most recently updated. Click through for detailed ratings on vegan options, gluten-free, workability, coffee craftsmanship, health focus, and pastries.</p>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/cafe/${post.slug}/`}>
									{post.heroImage && (
										<img src={post.heroImage} alt={post.title} width="720" height="360" loading="lazy" />
									)}
									<h4 class="title">{post.title}</h4>
									<p class="date">
										<FormattedDate date={post.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
</PostHogLayout>
