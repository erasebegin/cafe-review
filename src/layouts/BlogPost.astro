---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_URL } from '../consts';

import type { BlogPost as BlogPostType } from '../types/sanity';

type Props = {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: string;
	post?: BlogPostType;
};

const { title, description, pubDate, updatedDate, heroImage, post } = Astro.props;

// Compose page-level SEO title with brand suffix.
const metaTitle = post?.seoTitle || (post?.location?.cityName
	? `${title} — ${post.location.cityName} Cafe Review`
	: `${title} | ${SITE_TITLE}`);
const metaDescription = post?.seoDescription || description;
const pageUrl = post ? `${SITE_URL}/blog/${post.slug}` : SITE_URL;

// Compute an aggregate rating from the per-category 1–5 ratings (when present)
// for the Review schema. Schema.org `Rating.bestRating: 5`, `worstRating: 1`.
const ratingFields = [
	post?.veganOptions,
	post?.glutenFree,
	post?.workability,
	post?.coffeeCraftsmanship,
	post?.healthFocus,
	post?.pastries,
].filter((v): v is number => typeof v === 'number' && v > 0);
const avgRating = ratingFields.length > 0
	? Number((ratingFields.reduce((a, b) => a + b, 0) / ratingFields.length).toFixed(2))
	: undefined;

const itemReviewed: Record<string, unknown> = {
	'@type': 'CafeOrCoffeeShop',
	name: title,
	url: pageUrl,
	...(heroImage && { image: heroImage }),
	...(post?.address && { address: post.address }),
	...(post?.phone && { telephone: post.phone }),
	...(post?.openingHours && post.openingHours.length > 0 && { openingHours: post.openingHours }),
	...(post?.geo && {
		geo: {
			'@type': 'GeoCoordinates',
			latitude: post.geo.lat,
			longitude: post.geo.lng,
		},
	}),
};

const reviewJsonLd: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'Review',
	name: title,
	headline: title,
	description: metaDescription,
	url: pageUrl,
	...(heroImage && { image: heroImage }),
	datePublished: pubDate.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	author: {
		'@type': 'Organization',
		name: SITE_TITLE,
		url: SITE_URL,
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		url: SITE_URL,
		logo: {
			'@type': 'ImageObject',
			url: `${SITE_URL}/cafe-review-logo.png`,
		},
	},
	itemReviewed,
	...(avgRating !== undefined && {
		reviewRating: {
			'@type': 'Rating',
			ratingValue: avgRating,
			bestRating: 5,
			worstRating: 1,
		},
	}),
};

const breadcrumbItems: Array<Record<string, unknown>> = [
	{ '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
];
if (post?.location) {
	breadcrumbItems.push({
		'@type': 'ListItem',
		position: 2,
		name: post.location.cityName,
		item: `${SITE_URL}/${post.location.slug}`,
	});
	breadcrumbItems.push({ '@type': 'ListItem', position: 3, name: title, item: pageUrl });
} else {
	breadcrumbItems.push({ '@type': 'ListItem', position: 2, name: title, item: pageUrl });
}
const breadcrumbJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: breadcrumbItems,
};
---

<html lang="en">
	<head>
		<BaseHead
			title={metaTitle}
			description={metaDescription}
			image={heroImage}
			imageAlt={title}
			article={true}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(reviewJsonLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
			}

			article {
				position: relative;
				padding-bottom: 2rem;
			}
			.hero-image {
				margin: 3rem auto 0;
				max-width: 1020px;
				width: 100%;
				position: relative;
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.hero-image :global(header) {
				position: absolute;
				top: 1rem;
				right: 1rem;
				left: auto;
			}
			.hero-title-overlay {
				position: absolute;
				bottom: 0;
				left: 0;
				right: 0;
				padding: 1.5rem 2rem;
				background: rgba(255, 255, 255, 0.25);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border-top: 1px solid rgba(255, 255, 255, 0.35);
				border-radius: 0 0 12px 12px;
				box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.1);
			}
			.hero-title-overlay h1 {
				margin: 0;
				color: white;
				font-size: 2rem;
				font-weight: 700;
				text-shadow: 1px 2px 4px rgba(0, 0, 0, 0.5);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.last-updated-on {
				font-style: italic;
				text-align: right;
				color: rgb(var(--gray));
				margin-top: 2rem;
				padding-top: 1rem;
				border-top: 1px solid rgba(0, 0, 0, 0.1);
			}
		</style>
	</head>

	<body class="blog-post">
		<main>
			<article>
				<div class="hero-image">
					{heroImage && (
						<img
							src={heroImage}
							alt={title}
							width="1020"
							height="510"
							loading="eager"
							fetchpriority="high"
							decoding="sync"
						/>
					)}
					<Header location={post?.location?.cityName} locationSlug={post?.location?.slug} />
					<div class="hero-title-overlay">
						<h1>{title}</h1>
					</div>
				</div>
				<div class="prose">
					<slot />
					<div class="last-updated-on">
						Last updated on <FormattedDate date={updatedDate || pubDate} />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
