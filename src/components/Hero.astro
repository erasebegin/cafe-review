---
import { Image } from 'astro:assets';
import { getSiteConfig } from '../lib/sanity-utils';
import type { BlogPost } from '../types/sanity';
import chrisMap from '../assets/Chris_Map.jpg';
import { SITE_TITLE } from '../consts';

interface Props {
  cityName?: string;
  bannerImageUrls?: string[];
  showScrollIndicator?: boolean;
  featuredCafes?: BlogPost[];
}

const { cityName, bannerImageUrls, showScrollIndicator = false, featuredCafes = [] } = Astro.props;
const hasMultipleImages = bannerImageUrls && bannerImageUrls.length > 1;

let title = SITE_TITLE;

try {
  const siteConfig = await getSiteConfig();
  if (siteConfig) {
    title = siteConfig.title || title;
  }
} catch (error) {
  console.error('Failed to load site config:', error);
}
---

<section class="hero">
  <div class="hero-image">
    {bannerImageUrls && bannerImageUrls.length > 0 ? (
      bannerImageUrls.map((url, index) => (
        <img 
          key={index}
          src={url} 
          alt={cityName ? `${cityName} hero background ${index + 1}` : `Cafe hero background ${index + 1}`}
          class={`hero-slide ${index === 0 ? 'active' : ''}`}
          data-slide-index={index}
          width="1920"
          height="1080"
          loading={index === 0 ? 'eager' : 'lazy'}
          fetchpriority={index === 0 ? 'high' : 'auto'}
          decoding={index === 0 ? 'sync' : 'async'}
        />
      ))
    ) : (
      <Image src={chrisMap} alt="Cafe hero background" loading="eager" />
    )}
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    {featuredCafes.length > 0 ? (
      <div class="hero-center">
        <div class="title-container">
          <h1 class="site-title">{title}</h1>
          {cityName && (
            <h2 class="city-subtitle">{cityName}</h2>
          )}
        </div>
        <div class="latest-cafes-container">
          <h3 class="latest-cafes-title">Latest</h3>
          <div class="latest-cafes-grid">
            {featuredCafes.map((cafe) => (
              <a
                href={`/blog/${cafe.slug}/`}
                class="latest-cafe-card"
                aria-label={cafe.location?.cityName ? `Read review of ${cafe.title} in ${cafe.location.cityName}` : `Read review of ${cafe.title}`}
              >
                <div class="cafe-card-image">
                  {cafe.heroImage ? (
                    <img
                      src={cafe.heroImage}
                      alt={cafe.title}
                      width="400"
                      height="300"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="cafe-card-placeholder">No Image</div>
                  )}
                </div>
                <div class="cafe-card-info">
                  <h3 class="cafe-card-title">{cafe.title}</h3>
                  {cafe.location?.cityName && (
                    <span class="cafe-card-location">{cafe.location.cityName}</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    ) : (
      <div class="title-container title-top-left">
        <h1 class="site-title">{title}</h1>
      </div>
    )}
    {showScrollIndicator ? (
      <button class="scroll-indicator" aria-label="Scroll down" id="scroll-down-btn" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
        </svg>
      </button>
    ) : (
      <a href="/berlin/" class="map-pin" style="top: 55%; left: 63%;" aria-label="Berlin">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C7.802 0 4.403 3.403 4.403 7.602c0 5.44 7.597 16.398 7.597 16.398s7.597-10.958 7.597-16.398C19.597 3.403 16.198 0 12 0zm0 11.5c-2.209 0-4-1.791-4-4s1.791-4 4-4 4 1.791 4 4-1.791 4-4 4z"/>
        </svg>
        <span class="pin-label">Berlin</span>
      </a>
    )}
  </div>
</section>

<script>
  document.getElementById('scroll-down-btn')?.addEventListener('click', () => {
    window.scrollBy({ top: window.innerHeight, behavior: 'smooth' });
  });
</script>

{hasMultipleImages && (
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const slides = document.querySelectorAll('.hero-slide');
      if (slides.length <= 1) return;

      let currentSlide = 0;

      function showNextSlide() {
        // Remove active class from current slide
        slides[currentSlide].classList.remove('active');
        
        // Move to next slide
        currentSlide = (currentSlide + 1) % slides.length;
        
        // Add active class to new slide
        slides[currentSlide].classList.add('active');
      }

      // Change slide every 10 seconds
      setInterval(showNextSlide, 10000);
    });
  </script>
)}

<style>
  .hero {
    position: relative;
    height: 100vh;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
  }

  .hero-slide.active {
    opacity: 1;
  }

  .hero-fallback-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #8B4513 0%, #D2691E 25%, #CD853F 50%, #F4A460 75%, #DEB887 100%);
    z-index: 1;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(167, 199, 199, 0.3); /* Sky Blue overlay */
    z-index: 2;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
  }

  .hero-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 90%;
    max-width: 900px;
  }

  .title-container {
    border-radius: 50px;
    padding: 1rem 4rem;
    text-align: center;
    background: rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.35);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .title-top-left {
    width: auto;
    position: absolute;
    top: 8rem;
    left: 5rem;
    z-index: 4;
  }

  .latest-cafes-title {
    color: white;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0 0 1rem 0.25rem;
    text-shadow: 1px 2px 4px rgba(0, 0, 0, 0.3);
  }

  .latest-cafes-container {
    width: 95%;
    border-radius: 24px;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .latest-cafes-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .latest-cafe-card {
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.2);
    text-decoration: none;
    color: white;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .latest-cafe-card:hover {
    transform: translateY(-4px);
    background: rgba(0, 0, 0, 0.45);
  }

  .cafe-card-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .cafe-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .latest-cafe-card:hover .cafe-card-image img {
    transform: scale(1.05);
  }

  .cafe-card-placeholder {
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.8rem;
  }

  .cafe-card-info {
    padding: 0.75rem;
  }

  .cafe-card-title {
    font-size: 0.9rem;
    font-weight: 600;
    margin: 0;
    text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.7);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: white;
  }

  .cafe-card-location {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.85);
    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.6);
  }

  .site-title {
    color: white;
    font-size: 5rem;
    font-weight: 700;
    margin: 0;
    text-shadow: 1px 2px 4px rgba(0, 0, 0, 0.3);
  }

  .city-subtitle {
    position: relative;
    color: rgba(255, 255, 255, 0.9);
    font-size: 3rem;
    font-weight: 500;
    margin: 0.5rem 0 0 0;
    text-shadow: 1px 2px 4px rgba(0, 0, 0, 0.3);
  }

  .map-pin {
    position: absolute;
    width: 48px;
    height: 48px;
    color: var(--latte-orange);
    cursor: pointer;
    transform: translate(-50%, -100%);
    transition: all 0.3s ease;
    filter: drop-shadow(2px 2px 4px rgba(0, 0, 0, 0.5));
    text-decoration: none;
  }

  .map-pin:hover {
    color: var(--maple-brown);
    transform: translate(-50%, -100%) scale(1.2);
  }

  .map-pin svg {
    width: 100%;
    height: 100%;
  }

  .pin-label {
    cursor: pointer;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.8);
    color: white;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 1.5rem;
    white-space: nowrap;
    margin-top: 0.25rem;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    width: 48px;
    height: 48px;
    color: white;
    cursor: pointer;
    filter: drop-shadow(2px 2px 4px rgba(0, 0, 0, 0.5));
    animation: bounce 2s ease-in-out infinite;
    background: none;
    border: none;
    padding: 0;
  }

  .scroll-indicator svg {
    width: 100%;
    height: 100%;
  }

  @keyframes bounce {
    0%, 100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(10px);
    }
  }


  .hero-title {
    color: white;
    font-size: 4rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);
    line-height: 1.1;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    font-weight: 300;
    margin: 0 0 2rem 0;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.7);
    opacity: 0.9;
  }

  .hero-cta {
    margin-top: 2rem;
  }

  .cta-button {
    display: inline-block;
    padding: 1rem 2rem;
    background: #ff6b35;
    color: white;
    text-decoration: none;
    border-radius: 50px;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
  }

  .cta-button:hover {
    background: #e55a2b;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
  }

  /* Responsive design */
  @media (max-width: 768px) {
    .hero-center {
      width: 95%;
    }

    .title-container {
      padding: 1rem 2rem;
    }

    .title-top-left {
      top: 1rem;
      left: 1rem;
    }

    .latest-cafes-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .site-title {
      font-size: 4rem;
    }

    .city-subtitle {
      font-size: 2.5rem;
    }

    .map-pin {
      width: 36px;
      height: 36px;
    }

    .scroll-indicator {
      width: 40px;
      height: 40px;
      bottom: 1.5rem;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-subtitle {
      font-size: 1.2rem;
    }

    .hero-content {
      padding: 0 1rem;
    }

    .cta-button {
      padding: 0.8rem 1.6rem;
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .site-title {
      font-size: 3.25rem;
    }

    .city-subtitle {
      font-size: 2.5rem;
    }

    .latest-cafes-container {
      padding: 0.75rem;
    }

    .cafe-card-title {
      font-size: 0.8rem;
    }

    .map-pin {
      width: 32px;
      height: 32px;
    }

    .scroll-indicator {
      width: 36px;
      height: 36px;
      bottom: 1rem;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }
  }
</style>
