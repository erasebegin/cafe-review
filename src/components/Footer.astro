---
import { getAllLocations } from '../lib/sanity-utils';
import { SITE_TITLE } from '../consts';

const today = new Date();

let locations: Awaited<ReturnType<typeof getAllLocations>> = [];
try {
	locations = await getAllLocations();
} catch (error) {
	console.error('Footer: failed to load locations from Sanity:', error);
}
---

<footer>
	<div class="footer-grid">
		<nav class="footer-col" aria-label="Locations">
			<h3>Locations</h3>
			{locations.length > 0 ? (
				<ul>
					{locations.map((loc) => (
						<li>
							<a
								href={`/${loc.slug.current}/`}
								aria-label={`Browse cafes in ${loc.cityName}`}
							>
								{loc.cityName}
							</a>
						</li>
					))}
				</ul>
			) : (
				<p class="footer-empty">More cities coming soon.</p>
			)}
		</nav>
		<nav class="footer-col" aria-label="Site">
			<h3>Site</h3>
			<ul>
				<li><a href="/">Home</a></li>
				<li><a href="/about/">About</a></li>
				<li><a href="/sitemap/">Sitemap</a></li>
				<li><a href="/rss.xml">RSS feed</a></li>
			</ul>
		</nav>
	</div>
	<p class="footer-credit">
		&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.
	</p>
</footer>
<style>
	footer {
		padding: 2.5em 1.5em 2em;
		background: #E0E0E0;
		color: #616161;
		text-align: center;
	}
	.footer-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 2rem;
		max-width: 900px;
		margin: 0 auto 1.5rem;
		text-align: left;
	}
	.footer-col h3 {
		font-size: 0.95rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin: 0 0 0.5rem 0;
		color: #333;
	}
	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.footer-col li {
		line-height: 1.9;
	}
	.footer-col a {
		color: #ff6b35;
		text-decoration: none;
	}
	.footer-col a:hover {
		text-decoration: underline;
	}
	.footer-empty {
		color: #888;
		font-style: italic;
		margin: 0;
	}
	.footer-credit {
		margin: 0;
		font-size: 0.85rem;
	}
</style>
